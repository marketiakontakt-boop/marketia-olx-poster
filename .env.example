# Marketia OLX Poster — environment configuration
# Copy to .env and fill values. .env is gitignored.

# AI variants (Gemini 2.5 Flash — batchowe warianty opisów)
GEMINI_API_KEY=your-gemini-key-here

# Vision fallback (Claude API — gdy selectors zawiodą)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Proxy per konto (socks5 lub http). NULL/empty = brak proxy.
OLX_PROXY_MARKETIA_GLOWNE=
OLX_PROXY_MARKETIA_WARSZAWA=socks5://user:pass@warsaw-proxy.example.com:1080
OLX_PROXY_MARKETIA_KRAKOW=socks5://user:pass@krakow-proxy.example.com:1080

# Feature flags
ENABLE_VISION_FALLBACK=false
ENABLE_GEMINI_VARIANTS=true

# Logi
LOG_LEVEL=INFO
